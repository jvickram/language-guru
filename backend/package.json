{
  "name": "language-guru",
  "version": "1.0.0",
  "description": "A Node.js/Express server for the Language Guru project.",
  "main": "index.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "test": "jest --runInBand",
    "test:coverage": "jest --coverage --runInBand",
    "test:ci": "jest --ci --coverage --runInBand --watchman=false"
  },
  "dependencies": {
    "express": "^4.17.3",
    "mongoose": "^6.0.12",
    "jsonwebtoken": "^8.5.1",
    "bcryptjs": "^2.4.3",
    "dotenv": "^10.0.0",
    "joi": "^17.6.0"
  },
  "devDependencies": {
    "nodemon": "^2.0.12",
    "eslint": "^7.32.0",
    "jest": "^27.0.6",
    "supertest": "^7.0.0"
  },
  "jest": {
    "testEnvironment": "node",
    "collectCoverageFrom": [
      "src/**/*.js",
      "!src/**/__tests__/**"
    ]
  },
  "author": "jvickram",
  "license": "ISC"
}
