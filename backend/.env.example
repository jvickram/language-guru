# Runtime
NODE_ENV=development
PORT=3000

# Security
JWT_SECRET=change_this_in_production
JWT_EXPIRES_IN=7d
RATE_LIMIT_PER_MINUTE=120

# CORS (comma-separated). Use * for development.
ALLOWED_ORIGINS=*

# Data store mode: memory or mongo
DATA_STORE=memory

# Required when DATA_STORE=mongo
MONGO_URI=mongodb://localhost:27017/language_guru
